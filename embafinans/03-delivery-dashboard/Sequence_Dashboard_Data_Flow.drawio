        <!-- Agent: Near Customer update -->
        <mxCell id="m1c" value="1c: Update status → NEAR_CUSTOMER" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="147" y="220" as="sourcePoint"/>
            <mxPoint x="358" y="220" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

