        <mxCell id="n1" value="GPS coordinates updated&#xa;every 30 seconds during transit&#xa;Geofencing: 200m radius triggers&#xa;NEAR_CUSTOMER status" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rounded=0;" vertex="1" parent="1">
