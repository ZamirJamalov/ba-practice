        </mxCell>

        <!-- 1. Agent updates status (picked up) -->
        <mxCell id="m1" value="1: Update status → PICKED_UP (GPS coords, timestamp)" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="147" y="140" as="sourcePoint"/>
            <mxPoint x="358" y="140" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. API Gateway authenticates & routes -->
        <mxCell id="m2" value="2: POST /api/v1/delivery/status-update" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="372" y="190" as="sourcePoint"/>
            <mxPoint x="578" y="190" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 3. Delivery Service validates -->
        <mxCell id="m3" value="3: Validate agent ID &amp; delivery assignment" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="592" y="240" as="sourcePoint"/>
            <mxPoint x="793" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. Save to Tracking DB -->
        <mxCell id="m4" value="4: INSERT delivery_event (status, GPS, agent_id, delivery_id)" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="592" y="290" as="sourcePoint"/>
            <mxPoint x="793" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 5. DB confirms -->
        <mxCell id="m5" value="5: Acknowledge (event_id)" style="endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="793" y="350" as="sourcePoint"/>
            <mxPoint x="592" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 6. DB returns latest status -->
        <mxCell id="m6" value="6: Return latest delivery status" style="endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="793" y="400" as="sourcePoint"/>
            <mxPoint x="592" y="400" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 7. Publish event to WebSocket -->
        <mxCell id="m7" value="7: Publish update event (WebSocket channel)" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="592" y="530" as="sourcePoint"/>
            <mxPoint x="1023" y="530" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 8. Dashboard receives real-time update -->
        <mxCell id="m8" value="8: Receive real-time update → render on map" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1023" y="590" as="sourcePoint"/>
            <mxPoint x="1273" y="590" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 9. Send notification to customer -->
        <mxCell id="m9" value="9: Trigger customer notification (SMS/Push)" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="592" y="650" as="sourcePoint"/>
            <mxPoint x="1273" y="650" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 10. Return success to agent -->
        <mxCell id="m10" value="10: Return status update confirmed" style="endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="578" y="740" as="sourcePoint"/>
            <mxPoint x="372" y="740" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 11. Return to agent app -->
        <mxCell id="m11" value="11: Return confirmation to agent" style="endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="358" y="800" as="sourcePoint"/>
            <mxPoint x="147" y="800" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 12. Customer receives notification -->
        <mxCell id="m12" value="12: Send notification → Customer App" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1273" y="720" as="sourcePoint"/>
            <mxPoint x="147" y="880" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Agent: In Transit update -->
        <mxCell id="m1b" value="1b: Update status → IN_TRANSIT (GPS ping every 30s)" style="endArrow=block;endFill=1;curved=0;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="147" y="180" as="sourcePoint"/>
            <mxPoint x="358" y="180" as="targetPoint"/>
